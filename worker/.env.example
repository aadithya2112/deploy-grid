# Postgres connection string used to read and update deployment state.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Upstash Redis REST endpoint used to consume deployment jobs.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io

# Upstash Redis REST token used to authenticate queue reads.
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Queue name for deployment jobs; defaults to deployment_jobs when omitted.
DEPLOYMENT_QUEUE_NAME=deployment_jobs

# Secret used to decrypt project environment variables stored by the API.
PROJECT_ENV_ENCRYPTION_KEY=replace-with-the-same-secret-used-by-the-api

# Stable identity written into claimed build jobs for observability.
WORKER_ID=worker-1

# Base directory for temporary repo clones and build output staging.
WORKER_TMP_DIR=/tmp/deploy-grid-worker

# Lease duration for claimed jobs before another worker can recover them.
BUILD_JOB_LEASE_SECONDS=60

# Interval for extending the lease while a build is still running.
HEARTBEAT_INTERVAL_SECONDS=20

# Maximum number of full job attempts before a deployment is left failed.
MAX_BUILD_ATTEMPTS=3

# Public base URL for uploaded deployment artifacts, if applicable.
ARTIFACT_BASE_URL=https://artifacts.example.com

# Bucket or container name used to store uploaded build artifacts.
ARTIFACT_BUCKET=your-artifact-bucket

# Access key for the artifact storage provider.
ARTIFACT_ACCESS_KEY=your-artifact-access-key

# Secret key for the artifact storage provider.
ARTIFACT_SECRET_KEY=your-artifact-secret-key

# S3-compatible Cloudflare R2 endpoint used for uploads.
R2_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Public R2 bucket URL used when no custom artifact domain exists.
R2_PUBLIC_BASE_URL=https://pub-<id>.r2.dev

# Poll delay used when the queue is empty.
QUEUE_POLL_INTERVAL_MS=5000

# How often the worker scans for recoverable jobs.
RECOVERY_INTERVAL_SECONDS=30

# Timeout applied to install and build commands.
BUILD_TIMEOUT_SECONDS=900

# Total attempts for transient install/build command failures.
TRANSIENT_COMMAND_RETRY_LIMIT=2

# Delay between transient command retries.
TRANSIENT_COMMAND_RETRY_DELAY_MS=1000
