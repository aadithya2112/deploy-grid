# Port the Bun API server listens on.
PORT=3000

# Postgres connection string used by the API and Drizzle.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Upstash Redis REST endpoint used for deployment job dispatch.
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io

# Upstash Redis REST token used to authenticate queue writes.
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-rest-token

# Queue name for deployment jobs; defaults to deployment_jobs when omitted.
DEPLOYMENT_QUEUE_NAME=deployment_jobs

# Base URL used to generate deployment preview URLs.
DEPLOYMENT_PREVIEW_BASE_URL=https://preview.example.com

# Shared Bearer token for protecting API routes when auth is enabled.
API_AUTH_TOKEN=your-shared-api-token

# Secret used to encrypt and decrypt project environment variables at rest.
PROJECT_ENV_ENCRYPTION_KEY=replace-with-a-long-random-secret
