# Clerk publishable key (safe for browser).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Clerk secret key (server only).
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk auth route configuration.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Base URL for the Deploy Grid API.
# Used by server-side data fetching in the Next.js app.
DEPLOY_GRID_API_URL=http://localhost:3000

# Optional fallback API URL.
# Only set this if you specifically need a public browser-side URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Bearer token sent by the frontend to the API.
# Use the same value as API_AUTH_TOKEN in api/.env when auth is enabled.
DEPLOY_GRID_API_TOKEN=your-shared-api-token

# Optional compatibility alias for token lookup.
# If both are set, DEPLOY_GRID_API_TOKEN takes precedence.
API_AUTH_TOKEN=your-shared-api-token

# Test-only frontend E2E helpers.
# Leave unset in normal development and production.
E2E_TEST_MODE=0
E2E_TEST_USER_ID=e2e-user
